{
  "rules": {
    ".read": true,
    ".write": true,
    "users": {
      "$userId": {
        ".read": true,
        ".write": true
      }
    },
    "games": {
      "$gameId": {
        ".read": true,
        ".write": true
      }
    },
    "sheets": {
      "$sheetId": {
        ".read": true,
        ".write": true,
        ".indexOn": ["gameId"]
      }
    }
  }
}